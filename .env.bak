# Which provider to use: claude | openrouter | vllm
PROVIDER=claude

# --- Claude (Anthropic) ---
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenRouter ---
OPEN_ROUTER_API_KEY=
OPEN_ROUTER_MODEL=anthropic/claude-sonnet-4-6

# --- vLLM / Local ---
VLLM_API_URL=http://localhost:8000/v1/chat/completions
VLLM_MODEL=default
VLLM_API_KEY=
